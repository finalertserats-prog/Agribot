# --- AI provider: set AT LEAST ONE key. The bot uses whichever is present. ---
# Google Gemini — free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# OpenAI — key at https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Optional: force a provider when both keys are set (gemini | openai).
# If unset, the bot auto-selects (prefers Gemini when both keys exist).
# LLM_PROVIDER=gemini

# Optional model overrides (defaults shown).
# GEMINI_TEXT_MODEL=gemini-2.0-flash
# GEMINI_EMBED_MODEL=text-embedding-004
# OPENAI_TEXT_MODEL=gpt-4o-mini
# OPENAI_EMBED_MODEL=text-embedding-3-small

# Bot trigger word (default: agrifriend)
BOT_TRIGGER=agrifriend

# Log level: debug | info | warn | error
LOG_LEVEL=info

# --- Ops Copilot (optional, Phase B) ---
# Command the copilot runs to self-heal the bot when the heartbeat goes stale.
# e.g. pm2 restart agrifriend   (leave unset to alert-only, no auto-restart)
# OPS_RESTART_COMMAND=pm2 restart agrifriend
# Optional webhook (Slack/Telegram/ops channel) for alerts. NOT a WhatsApp send.
# OPS_WEBHOOK_URL=https://hooks.example.com/...
