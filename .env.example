# Gemini API Key — get from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Bot trigger word (default: agrifriend)
BOT_TRIGGER=agrifriend

# Log level: debug | info | warn | error
LOG_LEVEL=info

# --- Ops Copilot (optional, Phase B) ---
# Command the copilot runs to self-heal the bot when the heartbeat goes stale.
# e.g. pm2 restart agrifriend   (leave unset to alert-only, no auto-restart)
# OPS_RESTART_COMMAND=pm2 restart agrifriend
# Optional webhook (Slack/Telegram/ops channel) for alerts. NOT a WhatsApp send.
# OPS_WEBHOOK_URL=https://hooks.example.com/...
